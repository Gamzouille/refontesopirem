{
    "nom": "ping_avec_arp",
    "description": "Simulation d'une requ\u00eate ping entre deux machines n\u00e9cessitant une r\u00e9solution ARP pr\u00e9alable.",
    "machines": [
        {
            "id": "st1",
            "ip": "192.168.1.1",
            "mac": "AA:BB:CC:00:00:01"
        },
        {
            "id": "st2",
            "ip": "192.168.1.2",
            "mac": "AA:BB:CC:00:00:02"
        },
        {
            "id": "st3",
            "ip": "192.168.1.3",
            "mac": "AA:BB:CC:00:00:03"
        },
        {
            "id": "st4",
            "ip": "192.168.1.4",
            "mac": "AA:BB:CC:00:00:04"
        }
    ],
    "switch": {
        "id": "sw1",
        "ports": {
            "st1": "port1",
            "st2": "port2",
            "st3": "port3",
            "st4": "port4"
        }
    },
    "etapes": [
        {
            "type": "envoi_arp_request",
            "source": "st1",
            "destination_ip": "192.168.1.2",
            "message": "Qui a 192.168.1.2 ?",
            "trame": {
                "src_mac": "AA:BB:CC:00:00:01",
                "dst_mac": "FF:FF:FF:FF:FF:FF",
                "type": "ARP"
            }
        },
        {
            "type": "reponse_arp",
            "source": "st2",
            "destination_mac": "AA:BB:CC:00:00:01",
            "message": "192.168.1.2 est \u00e0 AA:BB:CC:00:00:02",
            "trame": {
                "src_mac": "AA:BB:CC:00:00:02",
                "dst_mac": "AA:BB:CC:00:00:01",
                "type": "ARP"
            }
        },
        {
            "type": "ping_request",
            "source": "st1",
            "destination": "st2",
            "message": "Echo request",
            "trame": {
                "src_mac": "AA:BB:CC:00:00:01",
                "dst_mac": "AA:BB:CC:00:00:02",
                "type": "ICMP"
            }
        },
        {
            "type": "ping_reply",
            "source": "st2",
            "destination": "st1",
            "message": "Echo reply",
            "trame": {
                "src_mac": "AA:BB:CC:00:00:02",
                "dst_mac": "AA:BB:CC:00:00:01",
                "type": "ICMP"
            }
        }
    ]
}